# Environment Configuration
# Copy this file to .env and update with your values

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production-with-secure-random-key
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=school_management_system
DB_USER=root
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CHARSET=utf8mb4

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Application Settings
APP_NAME=School Management System
APP_LOGO_URL=/static/images/logo.png

# Session Settings
SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Security Settings (Change in Production)
SECURE_SSL_REDIRECT=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY_REPORT_ONLY=False

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif

# Cache Configuration (Optional)
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=unique-snowflake

# REST Framework Settings
REST_FRAMEWORK_DEFAULT_PAGINATION=20
REST_FRAMEWORK_DEFAULT_FILTER=django_filters.rest_framework.DjangoFilterBackend

# Logging (Optional)
LOG_LEVEL=INFO
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890